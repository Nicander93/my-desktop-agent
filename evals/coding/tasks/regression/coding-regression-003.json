{
  "schemaVersion": 1,
  "id": "coding-regression-003",
  "title": "Repair an immutable nested update",
  "suite": "regression",
  "prompt": "Read README.md and repair updateUserTheme in src/preferences.js. Preserve the documented immutability guarantees. Do not edit verify.mjs or package.json. Run node verify.mjs after editing and report the result.",
  "workspace": {
    "fixture": "../fixtures/preferences-update-base"
  },
  "checks": [
    {
      "id": "preferences-module-present",
      "type": "file-exists",
      "path": "src/preferences.js"
    },
    {
      "id": "theme-parameter-used",
      "type": "file-contains",
      "path": "src/preferences.js",
      "includes": "theme"
    },
    {
      "id": "verification-command",
      "type": "command",
      "command": "node",
      "args": ["verify.mjs"],
      "stdoutIncludes": "verified"
    }
  ],
  "limits": {
    "maxTurns": 15,
    "timeoutMs": 180000,
    "maxChangedFiles": 1
  },
  "tags": ["regression", "immutability", "object-update", "command"]
}
