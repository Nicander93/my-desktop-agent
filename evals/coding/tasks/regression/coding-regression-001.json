{
  "schemaVersion": 1,
  "id": "coding-regression-001",
  "title": "Make Retry-After parsing strict and safe",
  "suite": "regression",
  "prompt": "Read README.md and use node verify.mjs to understand the failure. Fix src/retry-after.js so it meets the documented contract. Keep the change local: do not edit verify.mjs or package.json. Re-run node verify.mjs before reporting the result.",
  "workspace": {
    "fixture": "../fixtures/retry-after-base"
  },
  "checks": [
    {
      "id": "retry-after-module-present",
      "type": "file-exists",
      "path": "src/retry-after.js"
    },
    {
      "id": "strict-integer-guard",
      "type": "file-contains",
      "path": "src/retry-after.js",
      "includes": "Number.isInteger"
    },
    {
      "id": "verification-command",
      "type": "command",
      "command": "node",
      "args": ["verify.mjs"],
      "stdoutIncludes": "verified"
    }
  ],
  "limits": {
    "maxTurns": 15,
    "timeoutMs": 180000,
    "maxChangedFiles": 1
  },
  "tags": ["regression", "input-validation", "edge-cases", "command"]
}
