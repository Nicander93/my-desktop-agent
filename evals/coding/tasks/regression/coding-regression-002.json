{
  "schemaVersion": 1,
  "id": "coding-regression-002",
  "title": "Implement deterministic tag normalization",
  "suite": "regression",
  "prompt": "Read README.md, then implement normalizeTags in src/tags.js. The verifier covers normal and edge cases. Do not edit verify.mjs or package.json. Run node verify.mjs after editing and report the result.",
  "workspace": {
    "fixture": "../fixtures/normalize-tags-base"
  },
  "checks": [
    {
      "id": "tags-module-present",
      "type": "file-exists",
      "path": "src/tags.js"
    },
    {
      "id": "tags-export-present",
      "type": "file-contains",
      "path": "src/tags.js",
      "includes": "normalizeTags"
    },
    {
      "id": "verification-command",
      "type": "command",
      "command": "node",
      "args": ["verify.mjs"],
      "stdoutIncludes": "verified"
    }
  ],
  "limits": {
    "maxTurns": 15,
    "timeoutMs": 180000,
    "maxChangedFiles": 1
  },
  "tags": ["regression", "collections", "edge-cases", "command"]
}
