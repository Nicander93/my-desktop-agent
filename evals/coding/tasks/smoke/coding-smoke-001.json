{
  "schemaVersion": 1,
  "id": "coding-smoke-001",
  "title": "Complete a small isolated JavaScript module",
  "suite": "smoke",
  "prompt": "Read README.md in the current workspace. Implement src/greet.js as described there. Run node verify.mjs after editing, then briefly report the verification result.",
  "workspace": {
    "fixture": "../fixtures/greeting-base"
  },
  "checks": [
    {
      "id": "greeting-file",
      "type": "file-exists",
      "path": "src/greet.js"
    },
    {
      "id": "greeting-content",
      "type": "file-contains",
      "path": "src/greet.js",
      "includes": ["export function greet", "Hello, ${name}!"],
      "weight": 2
    },
    {
      "id": "verification-command",
      "type": "command",
      "command": "node",
      "args": ["verify.mjs"],
      "stdoutIncludes": "verified"
    }
  ],
  "limits": {
    "maxTurns": 8,
    "timeoutMs": 120000,
    "maxChangedFiles": 1
  },
  "tags": ["smoke", "filesystem", "edit", "command"]
}
