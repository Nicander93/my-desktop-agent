{
  "schemaVersion": 1,
  "id": "coding-regression-003",
  "version": "0.1.0",
  "title": "Repair an immutable nested update",
  "suite": "regression",
  "tags": ["immutability", "object-update", "command"],
  "prompt": "Repair updateUserTheme in src/preferences.js while preserving the documented immutability guarantees. Do not edit verify.mjs or package.json. Run node verify.mjs after editing.",
  "profile": "coding",
  "capabilities": ["read-project", "edit-code", "run-tests", "inspect-git-diff"],
  "fixture": "fixture",
  "verifier": {
    "unchangedPaths": ["verify.mjs", "package.json"],
    "commands": [{ "command": "node", "args": ["verify.mjs"], "stdoutIncludes": "verified" }],
    "checks": [{ "id": "theme-parameter-used", "type": "file-contains", "path": "src/preferences.js", "includes": "theme" }]
  },
  "limits": { "maxTurns": 15, "timeoutMs": 180000, "maxChangedFiles": 1 }
}
